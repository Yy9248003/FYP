    <pre class="small"><code>client/src/views/pages/exams.vue
// 列表加载与状态计算
getPageExams(...).then(resp => {
  const list = (resp.data || {}).data || [];
  list.forEach(item => { item.status = contrastNow(item.examTime); });
  this.pageInfos = list;
});

// 开始考试跳转
addExamLog({ token: this.$store.state.token, examId: id }).then(() => {
  this.$router.push({ path: 'answer', query: { id } });
});
</code></pre>
