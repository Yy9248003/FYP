<div class="section">
  <h3>7.6 角色视角的代码详解（管理员 Admin）</h3>
  <h4>7.6.1 题库管理：创建/编辑/导入/导出</h4>
  <p>题库管理页面负责题目 CRUD 与批量导入导出，并统一题型值为数字 0/1/2/3。以下为关键实现：</p>
  <pre class="small"><code>client/src/views/pages/adminQuestions.vue
// 加载题目与分页
async loadQuestions() {
  this.loading = true
  try {
    const response = await getAdminQuestions({
      page: this.pagination.current,
      pageSize: this.pagination.pageSize,
      keyword: this.searchKeyword,
      type: this.searchType,
      project: this.searchProject
    })
    if (response.code === 0) {
      this.questions = response.data.list
      this.pagination.total = response.data.total
    } else {
      this.$Message.error(response.msg || '加载题目列表失败')
    }
  } finally { this.loading = false }
}

// 选择题校验（不能为空，且单选仅一个正确选项）
validateOptions() {
  const hasEmpty = this.formData.options.some(o => !o.content.trim())
  if (hasEmpty) { this.$Message.warning('请填写所有选项内容'); return false }
  const correctCount = this.getCorrectOptionsCount()
  if (correctCount === 0) { this.$Message.warning('请至少选择一个正确答案'); return false }
  if (this.formData.type === 0 && correctCount > 1) {
    this.$Message.warning('单选题只能有一个正确答案'); return false
  }
  return true
}

// 新增题目载荷（与后端字段对齐：subjectId/answer/analyse）
async handleSubmit() {
  const valid = await this.$refs.formRef.validate(); if (!valid) return
  if ([0].includes(this.formData.type)) { if (!this.validateOptions()) return }
  if ([1,2,3].includes(this.formData.type) && !this.formData.correctAnswer) {
    this.$Message.warning('请输入正确答案'); return
  }
  let response
  if (this.isEdit) {
    response = await updateAdminQuestion(this.formData)
  } else {
    const payload = {
      name: this.formData.name,
      type: this.formData.type,
      subjectId: this.formData.project,
      answer: this.formData.correctAnswer,
      analyse: this.formData.analysis,
    }
    if (this.formData.type === 0) {
      payload['options[]'] = this.formData.options.map(o => o.content)
      payload['correctOptions[]'] = this.formData.options
        .map((o, i) => (o.isCorrect ? String(i) : null)).filter(i => i !== null)
    }
    response = await addAdminQuestion(payload)
  }
  if (response.code === 0) { this.$Message.success(this.isEdit ? '编辑成功' : '创建成功'); this.showModal=false; this.loadQuestions() }
}

// 批量导入（CSV）
async beforeImport(file) {
  const fd = new FormData(); fd.append('file', file); fd.append('subjectId', this.searchProject || '')
  const resp = await importAdminQuestions(fd)
  if (resp.code === 0) { this.$Message.success(`导入完成：成功 ${resp.data.created} 条，失败 ${resp.data.failed.length} 条`); this.loadQuestions() }
  return false
}

// 批量导出（CSV）
async exportCsv() {
  const filters = { subjectId: this.searchProject || '', search: this.searchKeyword || '', questionType: this.searchType !== '' ? this.searchType : '' }
  const resp = await exportAdminQuestions(filters)
  const blob = new Blob([resp.data || resp], { type: 'text/csv;charset=utf-8;' })
  const url = URL.createObjectURL(blob); const a = document.createElement('a')
  a.href = url; a.download = 'questions_export.csv'; document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url)
}
</code></pre>
  <p><strong>要点</strong>：</p>
  <ul>
    <li><strong>类型统一</strong>：前端用数字 0/1/2/3 表示题型，避免字符串匹配带来的后端不兼容。</li>
    <li><strong>选项校验</strong>：选择题必须至少一个正确选项；单选题最多一个正确选项。</li>
    <li><strong>CSV I/O</strong>：上传使用 FormData，下载用 Blob + a.click 触发保存。</li>
  </ul>

  <h4>7.6.2 后端 URL 与视图入口</h4>
  <pre class="small"><code>server/app/urls.py
urlpatterns = [
  path('admin/&lt;str:module&gt;/', app.views.AdminView.as_view()),
  # ... 其他模块
]
</code></pre>
  <p>后端以统一风格路由分发至 `AdminView`，通过 `module` 子路径区分列表/新增/更新/删除/导入/导出等子动作，返回体遵循 `BaseView.successData` 的 `{ code:0, msg, data }` 约定。</p>

  <h4>7.6.3 关联数据模型（简要）</h4>
  <pre class="small"><code>server/app/models.py
class Practises(models.Model):
  id = models.AutoField(primary_key=True)
  name = models.CharField(max_length=64)
  answer = models.TextField()
  analyse = models.TextField()
  type = models.IntegerField()  # 0/1/2/3
  createTime = models.CharField(max_length=19, db_column='create_time')
  project = models.ForeignKey(Projects, on_delete=models.CASCADE, db_column="project_id")

class Options(models.Model):
  id = models.AutoField(primary_key=True)
  name = models.CharField(max_length=64)
  practise = models.ForeignKey(Practises, on_delete=models.CASCADE, db_column="practise_id")
</code></pre>
  <p>题目与选项通过 `Options.practise` 关联。注意 `Practises` 已移除历史上的 `score` 字段，分值在不同业务（如试卷、任务）由关联表提供。</p>
</div>

<div class="section">
  <h3>7.7 角色视角的代码详解（教师 Teacher）</h3>
  <h4>7.7.1 考试审核与成绩发布</h4>
  <pre class="small"><code>client/src/views/pages/teacherExamLogs.vue
// 打开填空题审核
showAuditWin_1(row){
  this.answersForm = { studentId: row.studentId, type: 1, examId: row.examId };
  getAnswers(row.studentId, 1, row.examId).then(resp => {
    this.ansers_1 = resp.data; this.showAuditFlag_1 = true;
  });
}

// 打开编程题审核
showAuditWin_2(row){
  this.answersForm = { studentId: row.studentId, type: 3, examId: row.examId };
  getAnswers(row.studentId, 3, row.examId).then(resp => {
    this.ansers_2 = resp.data; this.showAuditFlag_2 = true;
  });
}

// 审核单题（正确/错误），随后刷新列表
auditLog(id, type, flag){
  this.$Modal.confirm({ title: '系统提示', content: '提交之后结果将无法修改，是否继续?', onOk: () => {
    aduitAnswerLog({ id, type, flag }).then(() => {
      getAnswers(this.answersForm.studentId, this.answersForm.type, this.answersForm.examId).then(resp => {
        if(type == 1){ this.ansers_1 = resp.data } else { this.ansers_2 = resp.data }
      });
      this.$Notice.success({ duration: 3, title: '审核成功' });
    });
  }});
}

// 成绩发布前检查是否还有待审题型
putScore(row){
  checkAnswers(row.studentId, row.examId).then(resp => {
    if(resp.data.flag){
      this.$Notice.warning({ title: '填空或编程未完全审核，不能发布成绩' });
    } else {
      this.$Modal.confirm({ title: '系统提示', content: '发布后无法修改，是否继续?', onOk: () => {
        putExamLog({ studentId: row.studentId, examId: row.examId }).then(() => {
          this.getPageInfo(1, this.pageSize);
          this.$Notice.success({ title: '发布成绩成功' });
        })
      }});
    }
  });
}
</code></pre>
  <p><strong>要点</strong>：</p>
  <ul>
    <li><strong>类型审核</strong>：以 `type=1/3` 区分填空/编程审核清单。</li>
    <li><strong>不可逆提示</strong>：审核提交、成绩发布均使用二次确认。</li>
    <li><strong>发布前校验</strong>：后端 `checkAnswers` 返回 `flag` 表示是否仍有待审项。</li>
  </ul>
</div>

<div class="section">
  <h3>7.8 角色视角的代码详解（学生 Student）</h3>
  <h4>7.8.1 练习试卷：开始/继续/错题专项/导出</h4>
  <pre class="small"><code>client/src/views/pages/practises.vue
// 开始练习（若后端提示继续，则弹窗继续）
async startPractice(paper) {
  const token = this.$store.state.token || sessionStorage.getItem('token');
  const response = await apiStartPractice(token, paper.id);
  if (response.code === 0) {
    this.currentPracticeLog = response.data.logId;
    if (response.data && response.data.message === '继续现有练习') {
      this.$Modal.confirm({ title: '继续练习', content: '检测到您有未完成的练习，是否继续？', onOk: () => this.continuePractice(paper) });
    } else { this.initializePractice(paper) }
  }
}

// 基于错题本生成专项练习
async generateWrong() {
  const token = this.$store.state.token || sessionStorage.getItem('token');
  const resp = await generateWrongPracticePaper(token, this.wrongForm.projectId || null, this.wrongForm.limit || 10);
  if (resp.code === 0) {
    const start = await apiStartPractice(token, resp.data.paperId)
    if (start.code === 0) {
      this.currentPracticeLog = start.data.logId
      this.$router.push({ name: 'answer', query: { type: 'practice', paperId: resp.data.paperId, mode: 'fixed', logId: this.currentPracticeLog } })
    }
  }
}

// 导出练习记录（CSV）
async downloadPracticeLogs(){
  const token = this.$store.state.token || sessionStorage.getItem('token');
  const resp = await exportPracticeLogs(token)
  const blob = new Blob([resp.data || resp], { type: 'text/csv;charset=utf-8;' })
  const url = URL.createObjectURL(blob); const a = document.createElement('a')
  a.href = url; a.download = 'practice_logs.csv'; document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url)
}
</code></pre>
