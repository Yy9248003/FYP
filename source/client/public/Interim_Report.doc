    <pre class="small"><code>client/src/views/pages/adminQuestions.vue
// 导出 CSV
const resp = await exportAdminQuestions(filters);
const blob = new Blob([resp.data || resp], { type: 'text/csv;charset=utf-8;' });

// 导入 CSV
const fd = new FormData(); fd.append('file', file); fd.append('subjectId', this.searchProject || '');
const resp = await importAdminQuestions(fd);

// 新增题目载荷（选择题附 options/correctOptions）
const payload = { name, type, subjectId: this.formData.project, answer, analyse };
if (this.formData.type === 0) {
  payload['options[]'] = this.formData.options.map(o => o.content);
  payload['correctOptions[]'] = this.formData.options
    .map((o, i) => (o.isCorrect ? String(i) : null))
    .filter(i => i !== null);
}
</code></pre>
