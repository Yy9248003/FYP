# Environment Configuration Template
# 环境配置模板文件
# Copy this file to .env and fill in your actual values
# 复制此文件为 .env 并填入您的实际值

# ===========================================
# Database Configuration
# 数据库配置
# ===========================================
# 数据库连接URL (推荐使用)
DATABASE_URL=mysql://root:123456@localhost:3306/db_exam

# 或者使用单独的数据库配置变量
DB_NAME=db_exam                    # 数据库名称
DB_USER=root                       # 数据库用户名
DB_PASSWORD=123456                 # 数据库密码 (请修改为您的实际密码)
DB_HOST=localhost                  # 数据库主机地址
DB_PORT=3306                       # 数据库端口

# ===========================================
# Django Configuration
# Django配置
# ===========================================
# Django安全密钥 (必须修改为随机字符串)
SECRET_KEY=your-secret-key-here

# 调试模式 (开发环境设为True，生产环境设为False)
DEBUG=True

# 允许的主机 (生产环境需要修改为实际域名)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ===========================================
# AI Service Configuration
# AI服务配置 (可选，用于AI智能评分和自动出题)
# ===========================================
# 智谱AI API密钥 (从 https://open.bigmodel.cn/ 获取)
ZHIPUAI_API_KEY=your-zhipuai-api-key

# 智谱AI API基础URL
ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 使用的AI模型（免费模型：glm-4-flash）
ZHIPUAI_MODEL=glm-4-flash

# ===========================================
# Redis Configuration (optional)
# Redis配置 (可选，用于缓存和会话存储)
# ===========================================
# 是否使用Redis缓存（开发环境设为False，生产环境设为True）
USE_REDIS=False

# Redis连接配置（仅在USE_REDIS=True时生效）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# ===========================================
# Email Configuration (optional)
# 邮件配置 (可选，用于发送通知邮件)
# ===========================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password

# ===========================================
# Security Settings
# 安全设置
# ===========================================
# CORS允许的源 (跨域请求配置)
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# CSRF信任的源 (CSRF保护配置)
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ===========================================
# Static Files Configuration
# 静态文件配置
# ===========================================
STATIC_URL=/static/
MEDIA_URL=/media/
STATIC_ROOT=/app/static
MEDIA_ROOT=/app/media

# ===========================================
# 配置说明
# ===========================================
# 1. 复制此文件为 .env: cp env.example .env
# 2. 修改数据库密码: DB_PASSWORD=your_actual_password
# 3. 生成安全密钥: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# 4. 配置AI密钥 (可选): 从 https://open.bigmodel.cn/ 获取API密钥
# 5. 生产环境设置: DEBUG=False, 修改ALLOWED_HOSTS为实际域名
